# Copy to .env and fill in real values. Never commit .env.

# Cytracom (only needed if pulling directly; fallback to Godwin's API otherwise)
CYTRACOM_API_TOKEN=
CYTRACOM_BASE_URL=https://api.cytracom.net/v1.0

# Godwin's calls-by-date-range API (preferred path)
GODWIN_API_URL=
GODWIN_API_TOKEN=

# Where to POST results
WEBHOOK_URL=
WEBHOOK_SECRET=

# Speaker ID + transcription
WHISPER_MODEL=small
CONFIDENCE_THRESHOLD=0.72
GREETING_SKIP_SECONDS=18.0
ENROLL_DIR=./enrollment_audio
EMBEDDINGS_PATH=./enrolled_voices/embeddings.json

# Whisper transcription bias: short text that pushes the model toward
# real shop names + tech roster. Update when adding/removing techs.
WHISPER_INITIAL_PROMPT=Steve's Computer Repair. Technicians: Stonewall, Isaiah, John, Steve.

# Voicemail-detection phrases (comma-separated, case-insensitive). When a
# segment transcript contains any of these, the segment is force-tagged
# auto_greeting at confidence 1.0 and the embedding match is bypassed.
# Update if Steve's voicemail recording changes wording.
VOICEMAIL_SIGNATURES=sorry we missed you,leave a message,after the tone,after the beep

# Local audio scratch (auto-deleted after processing)
SCRATCH_DIR=./scratch

# Logging
LOG_LEVEL=INFO

# Shared secret for admin endpoints (/enroll/import, /enroll/rebuild).
# Empty disables admin endpoints (open in dev). Set in prod.
ADMIN_SECRET=
